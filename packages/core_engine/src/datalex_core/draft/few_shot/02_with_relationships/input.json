        {
          "name": "order_id",
          "type": "integer",
          "description": "Foreign key to the parent order.",
          "constraints": ["not_null"]
        },
        {
          "name": "product_id",
          "type": "integer",
          "description": "Foreign key to the product.",
          "constraints": ["not_null"]
        },
        {
          "name": "quantity",
          "type": "integer",
