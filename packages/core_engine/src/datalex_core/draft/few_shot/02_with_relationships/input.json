        {
          "name": "customer_email",
          "type": "varchar",
          "description": "Primary email used for receipts.",
          "constraints": ["not_null"]
        }
      ],
      "refs": []
    },
    {
      "name": "fct_orders",
      "description": "Order fact table, one row per completed order.",
      "schema": "marts",
      "materialization": "table",
      "tags": ["mart"],
      "meta": {},
      "columns": [
        {
          "name": "order_id",
          "type": "integer",
          "description": "Primary key for the order.",
          "constraints": ["not_null", "unique"]
        },
        {
          "name": "customer_id",
          "type": "integer",
