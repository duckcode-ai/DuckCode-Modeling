{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://duckcode.dev/schemas/datalex/diagram.schema.json",
  "title": "DataLex diagram (ER diagram composed from entity files)",
  "type": "object",
  "required": ["kind", "name"],
  "additionalProperties": false,
  "properties": {
    "kind": { "const": "diagram" },
    "name": { "type": "string", "pattern": "^[a-z][a-z0-9_]*$" },
    "layer": { "type": "string", "enum": ["conceptual", "logical", "physical"] },
    "domain": { "type": "string" },
    "dialect": { "type": "string" },
    "title": { "type": "string" },
    "description": { "type": "string" },
    "entities": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "file": { "type": "string" },
          "name": { "type": "string" },
          "entity": { "type": "string" },
          "type": { "type": "string" },
          "layer": { "type": "string", "enum": ["conceptual", "logical", "physical"] },
          "logical_name": { "type": "string" },
          "description": { "type": "string" },
          "domain": { "type": "string" },
          "subject_area": { "type": "string" },
          "owner": { "type": "string" },
          "terms": { "type": "array", "items": { "type": "string" } },
          "tags": { "type": "array", "items": { "type": "string" } },
          "fields": {
            "type": "array",
            "items": { "type": "object", "additionalProperties": true }
          },
          "columns": {
            "type": "array",
            "items": { "type": "object", "additionalProperties": true }
          },
          "candidate_keys": {
            "type": "array",
            "items": { "type": "array", "items": { "type": "string" } }
          },
          "alternate_keys": {
            "type": "array",
            "items": { "type": "array", "items": { "type": "string" } }
          },
          "business_keys": {
            "type": "array",
            "items": { "type": "array", "items": { "type": "string" } }
          },
          "surrogate_key": { "type": "string" },
          "natural_key": { "type": "string" },
          "hash_key": { "type": "string" },
          "subtype_of": { "type": "string" },
          "discriminator": { "type": "string" },
          "x": { "type": "number" },
          "y": { "type": "number" },
          "width": { "type": "number" }
        }
      }
    },
    "edges_overrides": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "from": { "type": "string" },
          "to": { "type": "string" },
          "hidden": { "type": "boolean" },
          "label": { "type": "string" }
        }
      }
    },
    "relationships": {
      "description": "Cross-file relationships authored at the diagram level. Each entry connects two columns belonging to different model files referenced in `entities[]`; the edge is rendered on the canvas and persisted with the diagram rather than injected into the referenced model files. Use this for diagram-local FKs (drag-to-relate on the canvas, 'Add Relationship' dialog) that shouldn't mutate the underlying dbt / DataLex model YAML.",
      "type": "array",
      "items": {
        "type": "object",
        "required": ["from", "to"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string" },
          "from": {
            "type": "object",
            "required": ["entity"],
            "additionalProperties": false,
            "properties": {
              "entity": { "type": "string" },
              "field": { "type": "string" }
            }
          },
          "to": {
            "type": "object",
            "required": ["entity"],
            "additionalProperties": false,
            "properties": {
              "entity": { "type": "string" },
              "field": { "type": "string" }
            }
          },
          "cardinality": {
            "type": "string",
            "enum": ["one_to_one", "one_to_many", "many_to_one", "many_to_many"]
          },
          "identifying": { "type": "boolean" },
          "optional": { "type": "boolean" },
          "label": { "type": "string" },
          "verb": { "type": "string" },
          "relationship_type": { "type": "string" },
          "from_role": { "type": "string" },
          "to_role": { "type": "string" },
          "rationale": { "type": "string" },
          "source_of_truth": { "type": "string" },
          "description": { "type": "string" },
          "on_delete": { "type": "string" },
          "on_update": { "type": "string" }
        }
      }
    },
    "logic": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "target_model": { "type": "string" },
        "materialization": { "type": "string" },
        "sql": { "type": "string" }
      }
    },
    "dbt": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "source": { "type": "string" },
        "generated_sql": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "viz": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "layoutMode": { "type": "string" },
        "groupBySubjectArea": { "type": "boolean" },
        "edgeType": { "type": "string" }
      }
    },
    "notes": {
      "description": "Free-form sticky annotations authored on the canvas. Each note has an id, text body, position (`x`, `y`), and an optional color index selecting one of the stock annotation palettes. Notes are diagram-local — they are never injected into referenced model files.",
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string" },
          "text": { "type": "string" },
          "x": { "type": "number" },
          "y": { "type": "number" },
          "width": { "type": "number" },
          "height": { "type": "number" },
          "color": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "tags": {
      "type": "array",
      "items": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" }
    },
    "meta": { "type": "object", "additionalProperties": true }
  }
}
